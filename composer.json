{
    "name": "aiarmada/filament-tax",
    "description": "Filament admin panel for tax configuration",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "laravel",
        "filament",
        "tax",
        "vat",
        "admin",
        "commerce"
    ],
    "authors": [
        {
            "name": "AIArmada",
            "email": "dev@aiarmada.com"
        }
    ],
    "require": {
        "aiarmada/tax": "self.version",
        "filament/filament": "^5.6"
    },
    "suggest": {
        "aiarmada/customers": "Required for Customer/CustomerGroup exemption entity types",
        "filament/spatie-laravel-settings-plugin": "Required for the ManageTaxSettings page"
    },
    "autoload": {
        "psr-4": {
            "AIArmada\\FilamentTax\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AIArmada\\FilamentTax\\FilamentTaxServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}